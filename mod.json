{
    "geode": "5.7.1",
    "gd": {
        "win": "2.2081",
        "android": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },
    "id": "timestepyt.deltarune_textboxes",
    "name": "Deltarune Textboxes",
    "version": "v1.7.2-alpha.1",
    "developer": "TimeStepYT",
    "description": "Makes Popups look like Deltarune",
    "links": {
        "source": "https://github.com/TimeStepYT/DeltaruneTextboxes"
    },
    "tags": [
        "customization"
    ],
    "dependencies": {
        "geode.node-ids": ">=1.19.0",
        "alphalaneous.alphas-ui-pack": ">=v1.1.0"
    },
    "api": {
        "include": [
            "api/*.hpp"
        ]
    },
    "resources": {
        "sprites": [
            "resources/sprites/*.png"
        ],
        "fonts": {
            "Determination": {
                "size": 70,
                "path": "resources/fonts/DeterminationMono.ttf",
                "charset": "32-126,8226",
                "outline": 0
            },
            "ComicSans": {
                "size": 70,
                "path": "resources/fonts/ComicSansPixelAdjusted.ttf",
                "charset": "32-126,8226",
                "outline": 0
            },
            "Papyrus": {
                "size": 70,
                "path": "resources/fonts/PapyrusPixelAdjusted.ttf",
                "charset": "32-126,8226",
                "outline": 0
            }
        },
        "files": [
            "resources/sounds/*.wav",
            "resources/shaders/*",
            "resources/g.jpg"
        ]
    },
    "settings": {
        "keybind-left": {
            "type": "keybind",
            "name": "Left Choice",
            "default": ["Left", "Controller_Left", "Controller_LTHUMBSTICK_LEFT"]
        },
        "keybind-right": {
            "type": "keybind",
            "name": "Right Choice",
            "default": ["Right", "Controller_Right", "Controller_LTHUMBSTICK_RIGHT"]
        },
        "keybind-confirm": {
            "type": "keybind",
            "name": "Confirm",
            "default": ["Z", "Enter", "Controller_A"]
        },
        "keybind-skip": {
            "type": "keybind",
            "name": "Skip Text",
            "default": ["X", "Shift+RightShift", "Shift+LeftShift"]
        },

        "disableClickToProgress": {
            "name": "Don't progress by clicking",
            "type": "bool",
            "default": false,
            "description": "Disables <cy>clicking</c> to progress textboxes",
            "platforms": [
                "win",
                "mac"
            ]
        },
        "coloredPortraits": {
            "name": "Colored Portraits",
            "type": "bool",
            "default": false,
            "description": "<cr>Disables</c> the <cy>grayscale</c> effect on the <cj>dialog portraits</c>."
        },
        "noGradientOverlay": {
            "name": "Disable gradient",
            "type": "bool",
            "default": false,
            "description": "<cr>Disables</c> the <cy>gradient</c> that you can see on <cj>colored text</c>"
        },
        "noShadow": {
            "name": "Disable shadow",
            "description": "<cr>Disables</c> the <cp>shadow</c> <cy>behind the text</c>",
            "type": "bool",
            "default": false
        },
        "noAnimation": {
            "name": "No Animation",
            "description": "<cr>Disables</c> the <cj>animated background</c>. <cy>(the colors of the corners change)</c>",
            "type": "bool",
            "default": false
        },
        "undertaleBG": {
            "name": "Undertale Background",
            "description": "<cj>Changes the background</c> of the textbox to the <cr>Undertale</c> one",
            "type": "bool",
            "default": false
        },
        "textRollingPause": {
            "name": "Text Rolling Pause",
            "type": "float",
            "min": 0,
            "max": 5,
            "default": 0.8,
            "control": {
                "arrow-step": 0.1,
                "big-arrow-step": 1
            },
            "description": "How many <cy>30th</c>s of a second it should <cj>pause</c> between characters for the <cg>rolling effect</c>"
        },
        "textSound": {
            "name": "Text Sound",
            "type": "string",
            "default": "Default",
            "description": "The <cy>sound</c> that plays for <cj>every letter</c> when rolling out",
            "one-of": [
                "Default",
                "Typewriter",
                "Toriel",
                "Sans",
                "Papyrus",
                "Undyne",
                "Alphys",
                "Asgore",
                "Asriel",
                "Susie",
                "Ralsei",
                "Lancer",
                "Jevil",
                "Noelle",
                "Berdly",
                "Queen",
                "Spamton",
                "Spamton NEO",
                "Tenna",
                "Carol",
                "Gerson",
                "Jackenstein",
                "Flowery",
                "No Sound"
            ]
        }
    }
}